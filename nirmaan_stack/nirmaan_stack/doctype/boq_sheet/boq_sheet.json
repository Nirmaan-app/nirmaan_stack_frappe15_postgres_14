   "fieldtype": "Section Break",
   "label": "Commit Version"
  },
  {
   "default": "1",
   "description": "Per-(boq, sheet_name) commit version. Shared with the committed grid + nodes for the same commit. Set by the Phase-5 commit pipeline (Slice 3b). The sheet is now VERSIONED (freeze-and-supersede), not deleted on re-commit.",
   "fieldname": "commit_version",
   "fieldtype": "Int",
   "label": "Commit Version"
  },
  {
   "default": "1",
   "description": "Exactly one current version per (boq, sheet_name). Enforced by the commit pipeline (the prior current sheet is frozen via frappe.db.set_value -- NOT doc.save, which would re-serialize the list-valued area_dimensions JSON and hit get_valid_dict's 'cannot be a list').",
   "fieldname": "is_current",
   "fieldtype": "Check",
   "label": "Is Current"
  },
  {
   "description": "Commit timestamp; set by the Phase-5 commit pipeline (Slice 3b).",
   "fieldname": "committed_at",
   "fieldtype": "Datetime",
   "label": "Committed At",
   "read_only": 1
  },
  {
   "description": "When this committed sheet's priced workbook was last exported (Slice 5a). Stamped per exported sheet via frappe.db.set_value at export time (NOT doc.save -- the list-valued area_dimensions JSON throws on a full save). Drives the 'pricing changed since last export' staleness signal (compared against MAX(BoQ Cell Pricing.priced_at) on the current version).",
   "fieldname": "last_exported_at",
   "fieldtype": "Datetime",
   "label": "Last Exported At",
   "read_only": 1
  }
 ],
