  },
  {
   "fieldname": "supply_amount",
   "fieldtype": "Currency",
   "label": "Supply Amount",
   "read_only": 1
  },
  {
   "fieldname": "install_amount",
   "fieldtype": "Currency",
   "label": "Install Amount",
   "read_only": 1
  },
  {
   "fieldname": "total_amount",
   "fieldtype": "Currency",
   "in_list_view": 1,
   "label": "Total Amount",
   "read_only": 1
  },
  {
   "default": "0",
   "description": "Auto-set when qty=0 and at least one rate is set. Common in tender BoQs.",
   "fieldname": "is_rate_only",
   "fieldtype": "Check",
   "in_list_view": 1,
   "label": "Rate Only",
   "read_only": 1
  },
  {
   "default": "0",
   "description": "Set to prevent automatic recomputation of amount fields",
   "fieldname": "amount_override",
   "fieldtype": "Check",
   "label": "Amount Override"
  },
  {
   "fieldname": "notes",
   "fieldtype": "Text",
   "label": "Notes"
  },
  {
   "description": "Transient: populated by frontend before user edit, cleared after audit entry is written",
   "fieldname": "edit_reason",
   "fieldtype": "Data",
   "hidden": 1,
   "label": "Edit Reason",
   "no_copy": 1
  },
  {
   "fieldname": "review_provenance_section",
   "fieldtype": "Section Break",
   "label": "Review Provenance"
  },
  {
   "description": "Pre-commit review edit history, carried verbatim from the review row. List of {field, from, to, by, at, reason} (+ optional area / rate_subkey on per-area edits). Stored opaque -- the element shape is not validated here. KEPT on the node: Nirmaan Versions tracks only post-commit scalar edits and cannot reconstruct this pre-commit history.",
   "fieldname": "edit_log",
   "fieldtype": "JSON",
   "label": "Edit Log"
  },
  {
   "fieldname": "edited_by",
   "fieldtype": "Data",
   "label": "Edited By"
  },
  {
   "fieldname": "edited_at",
   "fieldtype": "Datetime",
   "label": "Edited At"
  },
  {
   "description": "Human annotation carried from the review row (not an edit; no provenance side-effects).",
   "fieldname": "remarks",
   "fieldtype": "Small Text",
   "label": "Remarks"
  },
  {
   "description": "Notes attached to this node, carried verbatim from the review row as a structured list. Stored opaque -- the element shape is parser-defined and not validated here. Distinct from the flat notes field; do not fold into notes.",
   "fieldname": "attached_notes",
   "fieldtype": "JSON",
   "label": "Attached Notes"
  }
 ],
