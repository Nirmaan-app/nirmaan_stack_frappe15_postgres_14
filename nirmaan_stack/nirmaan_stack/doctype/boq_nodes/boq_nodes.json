   "fieldname": "links_section",
   "fieldtype": "Section Break",
   "label": "Links"
  },
  {
   "fieldname": "boq",
   "fieldtype": "Link",
   "in_standard_filter": 1,
   "label": "BoQ",
   "options": "BOQs",
   "search_index": 1
  },
  {
   "description": "Primary upward tie: the committed BoQ Sheet this node belongs to. The boq link is kept denormalized and must equal this sheet's boq (enforced in the controller).",
   "fieldname": "sheet",
   "fieldtype": "Link",
   "in_standard_filter": 1,
   "label": "BoQ Sheet",
   "options": "BoQ Sheet",
   "search_index": 1
  },
  {
   "fieldname": "parent_node",
   "fieldtype": "Link",
   "label": "Parent Node",
   "options": "BOQ Nodes",
   "search_index": 1
  },
  {
   "fieldname": "node_details_section",
   "fieldtype": "Section Break",
   "label": "Node Details"
  },
  {
   "fieldname": "node_type",
   "fieldtype": "Select",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "label": "Node Type",
   "options": "Preamble\nLine Item"
  },
  {
   "depends_on": "eval:doc.node_type == 'Preamble'",
   "fieldname": "level",
   "fieldtype": "Int",
   "label": "Level"
  },
  {
   "description": "Human-override classification (the why-is-this-line-here provenance). Free Data; the assignable vocabulary is enforced upstream, not enumerated here. Populated at commit; the node's effective classification is resolved before write.",
   "fieldname": "human_classification",
   "fieldtype": "Data",
   "label": "Human Classification"
  },
  {
   "description": "Human-override parent (the -1 sentinel convention: -1 / unset = no override, >= 0 = reparent to that row index). Populated at commit; the resolved parent is written to parent_node.",
   "fieldname": "human_parent",
   "fieldtype": "Int",
   "label": "Human Parent"
  },
  {
   "default": "0",
   "description": "Human re-rooted this node to top-level (Option B layer, orthogonal to human_parent).",
   "fieldname": "human_is_root",
   "fieldtype": "Check",
   "label": "Human Root Override"
  },
  {
   "default": "0",
   "fieldname": "sort_order",
   "fieldtype": "Int",
   "label": "Sort Order"
  },
  {
   "fieldname": "code",
   "fieldtype": "Data",
   "label": "Code"
  },
  {
   "fieldname": "description",
   "fieldtype": "Text",
   "in_global_search": 1,
   "in_list_view": 1,
   "label": "Description"
  },
  {
   "fieldname": "source_row_number",
   "fieldtype": "Int",
   "label": "Source Row Number"
  },
  {
   "fieldname": "path",
   "fieldtype": "Data",
   "label": "Path",
   "read_only": 1,
   "search_index": 1
  },
  {
   "fieldname": "line_item_section",
   "fieldtype": "Section Break",
   "label": "Qty, Rates & Amounts"
